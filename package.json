    "eslint": "^10.6.0",
    "eslint-config-ts-prefixer": "^4.2.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "react": "^19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.12.0",
